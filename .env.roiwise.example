# Copy is not required. Prefer generating .env.roiwise with:
# ./scripts/generate-deploy-env.sh

NEXT_PUBLIC_SITE_URL=https://roiwise.com.br
NEXT_PUBLIC_SUPABASE_URL=https://roiwise.com.br/supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME_GENERATED_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_GENERATED_SERVICE_ROLE_KEY

POSTGRES_PASSWORD=CHANGE_ME_RANDOM_POSTGRES_PASSWORD
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET
JWT_EXPIRY=3600
ANON_KEY=CHANGE_ME_GENERATED_ANON_KEY
SERVICE_ROLE_KEY=CHANGE_ME_GENERATED_SERVICE_ROLE_KEY

SUPABASE_PUBLIC_URL=https://roiwise.com.br/supabase
API_EXTERNAL_URL=https://roiwise.com.br/supabase
SITE_URL=https://roiwise.com.br
ADDITIONAL_REDIRECT_URLS=https://roiwise.com.br

DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=CHANGE_ME_RANDOM_DASHBOARD_PASSWORD
SECRET_KEY_BASE=CHANGE_ME_RANDOM_64_PLUS_CHARS
REALTIME_DB_ENC_KEY=CHANGE_ME_16_CHARS
PG_META_CRYPTO_KEY=CHANGE_ME_RANDOM_32_PLUS_CHARS
S3_PROTOCOL_ACCESS_KEY_ID=CHANGE_ME_RANDOM_ACCESS_KEY
S3_PROTOCOL_ACCESS_KEY_SECRET=CHANGE_ME_RANDOM_SECRET_KEY

ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX
META_APP_SECRET=CHANGE_ME_META_APP_SECRET
META_APP_ID=
AUTOMATION_CRON_SECRET=CHANGE_ME_RANDOM_SECRET

AI_REQUEST_TIMEOUT_MS=30000
AI_CONTEXT_MESSAGE_LIMIT=20

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
DISABLE_SIGNUP=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

SMTP_ADMIN_EMAIL=admin@roiwise.com.br
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=ROIWise
